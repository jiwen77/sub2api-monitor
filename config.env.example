# sub2api-monitor configuration
# The monitor is passive: it reads Sub2API PostgreSQL tables and does not probe upstream APIs.

# Sub2API deployment directory. Its .env is read for POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB.
SUB2API_DIR=/opt/sub2api
POSTGRES_CONTAINER=sub2api-postgres
# POSTGRES_USER=sub2api
# POSTGRES_DB=sub2api
# POSTGRES_PASSWORD=  # normally inherited from /opt/sub2api/.env

# Telegram bot notification target.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true
# HTML enables bold headings and compact code-style labels in Telegram. Set empty to disable.
TELEGRAM_PARSE_MODE=HTML

# Telegram command polling. When the daemon is running, send /status in Telegram
# to fetch the current account state immediately. Only TELEGRAM_CHAT_ID is allowed
# by default; set TELEGRAM_ALLOWED_CHAT_IDS to a comma-separated list for more.
TELEGRAM_COMMANDS_ENABLED=true
TELEGRAM_COMMAND_POLL_INTERVAL_SECONDS=5
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DROP_PENDING_UPDATES=true

# Runtime files.
STATE_FILE=/var/lib/sub2api-monitor/state.json
LOG_FILE=/var/log/sub2api-monitor/monitor.log
TZ=Asia/Shanghai
POLL_INTERVAL_SECONDS=60
PSQL_TIMEOUT_SECONDS=20

# Account-status notifications.
SEND_STARTUP_SUMMARY=true
REDACT_IDENTIFIERS=true
DETAIL_LIMIT=12

# User-recharge notifications.
# Detects increases in users.total_recharged and sends a Telegram card.
USER_RECHARGE_ALERTS_ENABLED=true

# Upstream-error notifications.
# Default: notify provider/upstream 429 and 5xx errors, excluding client/key/auth/network-looking messages.
ERROR_LOOKBACK_MINUTES=30
ERROR_LIMIT_PER_POLL=500
ERROR_COOLDOWN_SECONDS=600
ALERT_EXISTING_ERRORS_ON_FIRST_RUN=false
UPSTREAM_ALLOWED_STATUS_CODES=429,500-599
UPSTREAM_EXCLUDE_REGEX=(?i)(api[\s_-]?key|user\s*key|invalid\s+key|unauthori[sz]ed|forbidden|permission|authentication|invalidated\s+oauth\s+token|network|timeout|timed\s*out|dns|connection\s+(?:reset|refused)|client\s+(?:closed|disconnect|cancel)|failed\s+to\s+read\s+request\s+body)

# Exit-proxy/network-error notifications. These are separate from provider/upstream errors.
PROXY_ERROR_ALERTS_ENABLED=true
PROXY_ERROR_INCLUDE_REGEX=(?i)(proxy|socks|tunnel|http\s*connect|connect\s*failed|network|timeout|timed\s*out|dns|enotfound|eai_again|connection\s+(?:reset|refused)|econnreset|econnrefused|etimedout|no\s+route|host\s+unreachable|tls|ssl|certificate)
PROXY_ERROR_EXCLUDE_REGEX=(?i)(api[\s_-]?key|user\s*key|invalid\s+key|unauthori[sz]ed|forbidden|permission|authentication|invalidated\s+oauth\s+token|failed\s+to\s+read\s+request\s+body|client\s+(?:closed|disconnect|cancel))

# Daily report scheduler, in TZ above.
DAILY_REPORT_HOUR=0
DAILY_REPORT_MINUTE=0
DAILY_CATCHUP=true
