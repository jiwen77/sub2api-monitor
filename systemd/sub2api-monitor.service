[Unit]
Description=Passive Sub2API account/upstream/usage monitor with Telegram alerts
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/sub2api-monitor
EnvironmentFile=/etc/sub2api-monitor/config.env
ExecStart=/usr/bin/python3 /opt/sub2api-monitor/sub2api_monitor.py --config /etc/sub2api-monitor/config.env daemon
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
